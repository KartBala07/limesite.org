rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own doc; admin can read all
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == "REPLACE_WITH_YOUR_FIREBASE_UID";
    }

    // Orders: user can read/write their own; admin reads all
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        request.auth.uid == "REPLACE_WITH_YOUR_FIREBASE_UID"
      );
      allow update: if request.auth != null && request.auth.uid == "REPLACE_WITH_YOUR_FIREBASE_UID";
    }

    // Page views: any signed-in user can write; only admin can read
    match /pageviews/{docId} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.uid == "REPLACE_WITH_YOUR_FIREBASE_UID";
    }
  }
}
